<idea-plugin>
    <id>com.monkey.ultracommentremover</id>

    <name>Ultra Comment Remover</name>

    <vendor email="monkeymoon832@gmail.com"
            url="https://github.com/MonkeyMoon104/Ultra-Comment-Remover-Plugin-IntellijIDEA">
        MonkeyMoon104
    </vendor>

    <description><![CDATA[
        Removes comments recursively from files, folders and entire projects using IntelliJ PSI.

        Features:
        <ul>
            <li>Recursive folder/project processing</li>
            <li>PSI-safe comment removal</li>
            <li>Multi-language support</li>
            <li>Project View context menu integration</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup
                id="UltraCommentRemover"
                displayType="BALLOON"
                isLogByDefault="false"/>
    </extensions>

    <actions>
        <action
                id="com.monkey.actions.RemoveCommentsAction"
                class="com.monkey.actions.RemoveCommentsAction"
                icon="/icons/removeComments.svg"
                text="Remove Comments"
                description="Remove comments recursively">
            <add-to-group
                    group-id="ProjectViewPopupMenu"
                    anchor="last"/>
        </action>
    </actions>
</idea-plugin>